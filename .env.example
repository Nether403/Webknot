# ============================================================
# WebKnot — Example Environment Variables
# Copy this file to .env and fill in your values.
# Never expose server secrets with a VITE_ prefix.
# ============================================================

# Server-only Gemini API key. Used by the Express proxy.
GEMINI_API_KEY=your_gemini_api_key_here

# Server configuration
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Optional server persistence/cache services
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CACHE_TTL=3600000
CACHE_MAX_SIZE=1000

# Client-public backend API configuration
VITE_API_URL=http://localhost:3001
VITE_ENABLE_BACKEND_CACHE=true

# Client-public feature flags
VITE_AI_ENABLED=true
VITE_AI_RATE_LIMIT=20
